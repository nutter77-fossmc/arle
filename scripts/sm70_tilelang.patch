+TL_DEVICE unsigned bf16x2_to_f16x2_sm70(unsigned packed_bf16) {
+  union PackedBf16 {
+    unsigned u;
+    bfloat16_t v[2];
+  } in;
+  in.u = packed_bf16;
+  return __pack_half2(half_t(static_cast<float>(in.v[0])),
+                      half_t(static_cast<float>(in.v[1])));
+}
